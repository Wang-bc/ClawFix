HOST=0.0.0.0
PORT=3000
WORKSPACE_DIR=./workspace
PUBLIC_DIR=./public

# LLM
# Set ENABLE_LLM=true after you provide a valid API key.
ENABLE_LLM=false
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_API_STYLE=auto
OPENAI_MODEL=gpt-4.1
OPENAI_SUMMARY_MODEL=gpt-4.1-mini
OPENAI_TEMPERATURE=0.2
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_FALLBACK_MODELS=text-embedding-3-small,text-embedding-3-large
OPENAI_EMBEDDING_DIMENSIONS=1536

# Retrieval
ENABLE_VECTOR_SEARCH=true
VECTOR_BACKEND=qdrant
QDRANT_MODE=auto
QDRANT_URL=
QDRANT_API_KEY=
QDRANT_KNOWLEDGE_COLLECTION=clawfix_knowledge
QDRANT_CASES_COLLECTION=clawfix_cases
QDRANT_SESSION_COLLECTION=clawfix_session_memory
QDRANT_LOCAL_PATH=./workspace/.qdrant
VECTOR_TOP_K=6
LEXICAL_TOP_K=12
RERANK_TOP_N=12

# Web search
# Set ENABLE_WEB_SEARCH=true after you provide a valid Tavily key.
ENABLE_WEB_SEARCH=false
WEB_SEARCH_TIMEOUT_S=10
WEB_SEARCH_PROVIDER=tavily
TAVILY_API_KEY=
TAVILY_BASE_URL=https://api.tavily.com
TAVILY_SEARCH_DEPTH=advanced
TAVILY_EXTRACT_DEPTH=advanced
TAVILY_TOPIC=general

# Session and delivery
MAX_CONTEXT_CHARS=24000
SESSION_COMPACT_THRESHOLD_CHARS=16000
MAX_REPLY_CHARS=4800
MAX_SEARCH_RESULTS=5
MAX_DELIVERY_RETRIES=4
DELIVERY_POLL_INTERVAL_S=2

# Feishu
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CONNECTION_MODE=websocket
